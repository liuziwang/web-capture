{
  "manifest_version": 3,
  "name": "Web Structure Archiver",
  "version": "2.2.0",
  "description": "扫描当前网页的结构代码与静态资源，重写为本地相对路径并打包为 zip 下载。支持资源抓取重试与超时控制，提升复杂站点抓取稳定性。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "归档当前网页",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo/icon16.png",
      "48": "logo/icon48.png",
      "128": "logo/icon128.png"
    }
  },
  "icons": {
    "16": "logo/icon16.png",
    "48": "logo/icon48.png",
    "128": "logo/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "capture.js",
        "runner.js",
        "logo/icon16.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
